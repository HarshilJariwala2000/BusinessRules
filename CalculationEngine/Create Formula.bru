meta {
  name: Create Formula
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/v1/formula/create
  body: json
  auth: inherit
}

body:json {
  {
    "categoryId":1,
    "targetAttribute":1,
    "formula":"mrp + map"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000
}

settings {
  encodeUrl: true
  timeout: 0
}
